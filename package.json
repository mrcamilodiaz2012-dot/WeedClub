{
  "name": "WeedClub",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "seed": "node scripts/seed/seed.js",
    "seed:reset": "node scripts/seed/reset.js",
    "seed:reseed": "node scripts/seed/reseed.js"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "mapbox-gl": "^3.24.1",
    "react-map-gl": "^8.1.1"
  }
}
